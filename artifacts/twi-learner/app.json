{
  "expo": {
    "name": "Twi Alphabet & Numeral Reciter",
    "slug": "twi-learner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "twi-learner",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8961E"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.odoba158.twilearner",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#E8961E"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "aef43a9c-d6e5-4f87-9759-45e13294e265"
      }
    }
  }
}
